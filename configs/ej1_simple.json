{
  "base": {
    "name": "fraud",
    "data": "data/fraud_dataset.csv",
    "label": "flagged_fraud",
    "epochs": 1000,
    "epsilon": 0.01,
    "tolerance": 0.5,
    "normalize": "standard",
    "beta": 1.0,
    "workers": 6
  },
  "grid": {
    "test_per": [0.20, 0.30],
    "lr":       [0.01, 0.03, 0.1],
    "seed":     [1],
    "activation": ["tanh", "logistic", "relu"]
  }
}